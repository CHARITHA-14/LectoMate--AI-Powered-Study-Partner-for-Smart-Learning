# Backend environment variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=production

# JWT — use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# MongoDB — use MongoDB Atlas connection string in production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/lectomate?retryWrites=true&w=majority

# Google Gemini API key
OPENAI_API_KEY=your_gemini_api_key_here

# File uploads
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Frontend URL (your Vercel/Netlify URL) — used for CORS
FRONTEND_URL=https://your-app.vercel.app
